rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ═══════════════════════════════════════
    // 공통 검증 함수
    // ═══════════════════════════════════════

    // 게시글 생성 시 필수 필드 검증
    function validPost(data) {
      return data.keys().hasAll(['title', 'content', 'authorId', 'createdAt'])
          && data.title is string
          && data.title.size() > 0
          && data.title.size() <= 200
          && data.content is string
          && data.content.size() > 0
          && data.authorId is string
          && data.authorId.size() > 0;
    }

    // 게시글 공개 업데이트 허용 필드 (좋아요·공지·조회수·댓글수·신고수)
    function postUpdateOnly() {
      return request.resource.data.diff(resource.data)
             .affectedKeys()
             .hasOnly(['likes', 'likeCount', 'isPinned', 'commentCount', 'views', 'reportCount']);
    }

    // 작성자 본인의 내용 수정 허용 필드
    function postContentEditOnly() {
      return request.resource.data.diff(resource.data)
             .affectedKeys()
             .hasOnly(['title', 'content', 'prefix', 'updatedAt']);
    }

    // 댓글 수정 허용 필드 (좋아요만 변경 가능)
    function commentUpdateOnly() {
      return request.resource.data.diff(resource.data)
             .affectedKeys()
             .hasOnly(['likes', 'likeCount']);
    }

    // 댓글 생성 시 필수 필드 검증
    function validComment(data) {
      return data.keys().hasAll(['content', 'authorId', 'createdAt'])
          && data.content is string
          && data.content.size() > 0
          && data.content.size() <= 3000
          && data.authorId is string
          && data.authorId.size() > 0;
    }

    // ═══════════════════════════════════════
    // 회원 정보
    // ═══════════════════════════════════════
    match /users/{userId} {
      allow read: if true;

      // 본인 이메일로만 자가 가입 (Firebase Auth 필수, memberType은 'member'만)
      // 관리자 대신 등록은 createAdminUser Cloud Function에서 처리 (Admin SDK 경유)
      allow create: if request.auth != null
                    && request.auth.token.email == userId
                    && !exists(/databases/$(database)/documents/users/$(userId))
                    && request.resource.data.memberType == 'member'
                    && !('adminToken' in request.resource.data);

      // memberType / adminToken 직접 변경 차단 (Cloud Function에서만 처리)
      allow update: if !request.resource.data.diff(resource.data)
                        .affectedKeys().hasAny(['memberType', 'adminToken']);
      allow delete: if true;
    }

    // ═══════════════════════════════════════
    // 이메일 OTP (Cloud Function Admin SDK 전용)
    // ═══════════════════════════════════════
    match /email_otps/{emailDoc} {
      allow read, write: if false;
    }

    // ═══════════════════════════════════════
    // AI 이미지 (Cloud Function에서만 생성)
    // ═══════════════════════════════════════
    match /ai_images/{imgId} {
      allow read: if true;
      allow write: if false;
    }

    // ═══════════════════════════════════════
    // 게시판 — Firebase Auth 기반 권한
    // 생성: 로그인 + 본인 이메일이 authorId와 일치
    // 수정: 공개 필드(좋아요 등) OR 작성자 본인 내용 수정
    // 삭제: 로그인한 사용자 (작성자+매니저 UI에서 검증)
    // ═══════════════════════════════════════

    match /posts_vn_life/{postId} {
      allow read: if true;
      allow create: if request.auth != null
                    && request.auth.token.email == request.resource.data.authorId
                    && validPost(request.resource.data);
      allow update: if postUpdateOnly()
                    || (request.auth != null
                        && request.auth.token.email == resource.data.authorId
                        && postContentEditOnly());
      allow delete: if request.auth != null;
    }
    match /posts_vn_life/{postId}/comments/{commentId} {
      allow read: if true;
      allow create: if request.auth != null && validComment(request.resource.data);
      allow update: if commentUpdateOnly();
      allow delete: if request.auth != null;
    }

    match /posts_kr_life/{postId} {
      allow read: if true;
      allow create: if request.auth != null
                    && request.auth.token.email == request.resource.data.authorId
                    && validPost(request.resource.data);
      allow update: if postUpdateOnly()
                    || (request.auth != null
                        && request.auth.token.email == resource.data.authorId
                        && postContentEditOnly());
      allow delete: if request.auth != null;
    }
    match /posts_kr_life/{postId}/comments/{commentId} {
      allow read: if true;
      allow create: if request.auth != null && validComment(request.resource.data);
      allow update: if commentUpdateOnly();
      allow delete: if request.auth != null;
    }

    match /posts_free/{postId} {
      allow read: if true;
      allow create: if request.auth != null
                    && request.auth.token.email == request.resource.data.authorId
                    && validPost(request.resource.data);
      allow update: if postUpdateOnly()
                    || (request.auth != null
                        && request.auth.token.email == resource.data.authorId
                        && postContentEditOnly());
      allow delete: if request.auth != null;
    }
    match /posts_free/{postId}/comments/{commentId} {
      allow read: if true;
      allow create: if request.auth != null && validComment(request.resource.data);
      allow update: if commentUpdateOnly();
      allow delete: if request.auth != null;
    }

    match /posts_travel/{postId} {
      allow read: if true;
      allow create: if request.auth != null
                    && request.auth.token.email == request.resource.data.authorId
                    && validPost(request.resource.data);
      allow update: if postUpdateOnly()
                    || (request.auth != null
                        && request.auth.token.email == resource.data.authorId
                        && postContentEditOnly());
      allow delete: if request.auth != null;
    }
    match /posts_travel/{postId}/comments/{commentId} {
      allow read: if true;
      allow create: if request.auth != null && validComment(request.resource.data);
      allow update: if commentUpdateOnly();
      allow delete: if request.auth != null;
    }

    match /posts_food/{postId} {
      allow read: if true;
      allow create: if request.auth != null
                    && request.auth.token.email == request.resource.data.authorId
                    && validPost(request.resource.data);
      allow update: if postUpdateOnly()
                    || (request.auth != null
                        && request.auth.token.email == resource.data.authorId
                        && postContentEditOnly());
      allow delete: if request.auth != null;
    }
    match /posts_food/{postId}/comments/{commentId} {
      allow read: if true;
      allow create: if request.auth != null && validComment(request.resource.data);
      allow update: if commentUpdateOnly();
      allow delete: if request.auth != null;
    }

    match /posts_trade/{postId} {
      allow read: if true;
      allow create: if request.auth != null
                    && request.auth.token.email == request.resource.data.authorId
                    && validPost(request.resource.data);
      allow update: if postUpdateOnly()
                    || (request.auth != null
                        && request.auth.token.email == resource.data.authorId
                        && postContentEditOnly());
      allow delete: if request.auth != null;
    }
    match /posts_trade/{postId}/comments/{commentId} {
      allow read: if true;
      allow create: if request.auth != null && validComment(request.resource.data);
      allow update: if commentUpdateOnly();
      allow delete: if request.auth != null;
    }

    match /posts_qna/{postId} {
      allow read: if true;
      allow create: if validPost(request.resource.data);
      allow update: if postUpdateOnly();
      allow delete: if true;
    }
    match /posts_qna/{postId}/comments/{commentId} {
      allow read: if true;
      allow create: if validComment(request.resource.data);
      allow update: if commentUpdateOnly();
      allow delete: if true;
    }

    match /posts_photo/{postId} {
      allow read: if true;
      allow create: if validPost(request.resource.data);
      allow update: if postUpdateOnly();
      allow delete: if true;
    }
    match /posts_photo/{postId}/comments/{commentId} {
      allow read: if true;
      allow create: if validComment(request.resource.data);
      allow update: if commentUpdateOnly();
      allow delete: if true;
    }

    match /posts_travel_north/{postId} {
      allow read: if true;
      allow create: if validPost(request.resource.data);
      allow update: if postUpdateOnly();
      allow delete: if true;
    }
    match /posts_travel_north/{postId}/comments/{commentId} {
      allow read: if true;
      allow create: if validComment(request.resource.data);
      allow update: if commentUpdateOnly();
      allow delete: if true;
    }

    match /posts_travel_central/{postId} {
      allow read: if true;
      allow create: if validPost(request.resource.data);
      allow update: if postUpdateOnly();
      allow delete: if true;
    }
    match /posts_travel_central/{postId}/comments/{commentId} {
      allow read: if true;
      allow create: if validComment(request.resource.data);
      allow update: if commentUpdateOnly();
      allow delete: if true;
    }

    match /posts_travel_south/{postId} {
      allow read: if true;
      allow create: if validPost(request.resource.data);
      allow update: if postUpdateOnly();
      allow delete: if true;
    }
    match /posts_travel_south/{postId}/comments/{commentId} {
      allow read: if true;
      allow create: if validComment(request.resource.data);
      allow update: if commentUpdateOnly();
      allow delete: if true;
    }

    // ═══════════════════════════════════════
    // 쪽지 — 필드 검증 + 수정 제한
    // ═══════════════════════════════════════
    match /messages/{msgId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAll(['to', 'from', 'subject', 'body', 'createdAt'])
                   && request.resource.data.to is string
                   && request.resource.data.to.size() > 0
                   && request.resource.data.from is string
                   && request.resource.data.from.size() > 0
                   && request.resource.data.subject is string
                   && request.resource.data.subject.size() > 0
                   && request.resource.data.body is string
                   && request.resource.data.body.size() > 0;
      // 수정: 읽음 표시(read 필드)만 허용 — 내용 변조 차단
      allow update: if request.resource.data.diff(resource.data)
                       .affectedKeys().hasOnly(['read']);
      allow delete: if true;
    }

    // ═══════════════════════════════════════
    // 상담 신청
    // ═══════════════════════════════════════
    match /consultations/{docId} {
      allow create: if true;
      allow read: if true;
      allow update, delete: if false;
    }

    // ═══════════════════════════════════════
    // 성공사례 / FAQ
    // ═══════════════════════════════════════
    match /success_stories/{docId} {
      allow read: if true;
      allow write: if true;
    }
    match /faqs/{docId} {
      allow read: if true;
      allow write: if true;
    }

    // ═══════════════════════════════════════
    // 신고
    // ═══════════════════════════════════════
    match /reports/{reportId} {
      allow create: if true;
      allow read, delete: if true;
      allow update: if false;
    }

    // ═══════════════════════════════════════
    // 사이트 설정 (금칙어 등)
    // ═══════════════════════════════════════
    match /settings/{docId} {
      allow read: if true;
      allow write: if true;
    }

    // ═══════════════════════════════════════
    // 실시간 채팅
    // ═══════════════════════════════════════
    match /chats/{chatId} {
      allow read, write: if true;
      match /messages/{msgId} {
        allow read, write: if true;
      }
    }
  }
}
