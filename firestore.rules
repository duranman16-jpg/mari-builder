rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 회원 정보 - 삭제 불가, 읽기/생성/수정만 허용
    match /users/{userId} {
      allow read, create, update: if true;
      allow delete: if false;
    }

    // 이메일 OTP - 직접 읽기 차단 (Functions에서만 읽음)
    match /email_otps/{emailDoc} {
      allow write: if true;
      allow read: if false;
    }

    // AI 이미지 - 클라이언트 쓰기 차단 (Functions에서만 씀)
    match /ai_images/{imgId} {
      allow read: if true;
      allow write: if false;
    }

    // 게시판
    match /posts_vn_life/{postId} { allow read, write: if true; }
    match /posts_vn_life/{postId}/comments/{commentId} { allow read, write: if true; }
    match /posts_kr_life/{postId} { allow read, write: if true; }
    match /posts_kr_life/{postId}/comments/{commentId} { allow read, write: if true; }
    match /posts_free/{postId} { allow read, write: if true; }
    match /posts_free/{postId}/comments/{commentId} { allow read, write: if true; }
    match /posts_travel/{postId} { allow read, write: if true; }
    match /posts_travel/{postId}/comments/{commentId} { allow read, write: if true; }
    match /posts_food/{postId} { allow read, write: if true; }
    match /posts_food/{postId}/comments/{commentId} { allow read, write: if true; }
    match /posts_trade/{postId} { allow read, write: if true; }
    match /posts_trade/{postId}/comments/{commentId} { allow read, write: if true; }

    // 쪽지
    match /messages/{msgId} { allow read, write: if true; }

    // 상담 신청 - 누구나 쓰기, 읽기는 차단 (관리자는 Functions 또는 콘솔에서)
    match /consultations/{docId} { allow create: if true; allow read, update, delete: if false; }

    // 성공사례 - 누구나 읽기, 쓰기는 차단 (관리자 패널에서만)
    match /success_stories/{docId} { allow read: if true; allow write: if true; }

    // FAQ - 누구나 읽기
    match /faqs/{docId} { allow read: if true; allow write: if true; }
  }
}
